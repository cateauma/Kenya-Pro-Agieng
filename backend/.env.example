# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
# Supabase: Dashboard → Project Settings → Database → Connection string.
# If "Direct" gives ENOTFOUND, use "Session pooler" or "Transaction pooler" URI instead.
# Example pooler: postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# JWT (use a long random string in production)
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins, or * for dev)
CORS_ORIGIN=http://localhost:5173

# Log every query and params sent to the DB (on in development, set to 0 to disable)
# LOG_DB=1

# Use local JSON file instead of PostgreSQL (backend/data/store.json). No DB required.
USE_JSON_STORE=1
